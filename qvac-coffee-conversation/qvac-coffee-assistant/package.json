{
  "name": "qvac-coffee-assistant",
  "version": "2.1.0",
  "description": "QVAC Runtime Experiments - Agentic Coffee Ordering Assistant with WDK Payment Layer and Shop/Wallet UIs",
  "type": "module",
  "scripts": {
    "start": "node patch-sdk.mjs && concurrently \"bun run coffee-shop-api/server.ts\" \"bun run examples/agent-ui-server.ts\"",
    "ui": "node patch-sdk.mjs && bun run examples/agent-ui-server.ts",
    "wallet": "bun run qvac-wallet/wallet-server.ts",
    "test:agent": "bun run examples/test-harness.ts",
    "test:btc": "bun run scripts/test-btc.ts",
    "test:lightning": "bun run scripts/test-lightning.ts",
    "test:wallet:phoenixd": "bun run qvac-wallet-phoenixd/test-wallet.ts",
    "qvac-api": "bun --env-file=.env.qvac run coffee-shop-api/server.ts",
    "coffee-api": "bun --env-file=.env.coffee run coffee-shop-api/server.ts",
    "api:testnet": "USE_REAL_PAYMENTS=true bun --env-file=.env.coffee run coffee-shop-api/server.ts",
    "api:usdt": "bun --env-file=.envUSDT_ERC20 run coffee-shop-api/server.ts",
    "generate:wallet": "bun run scripts/generate-wallet.ts",
    "download:voices": "bun run scripts/download-tts-voices.ts",
    "setup:models": "bun run scripts/setup-models.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "patch": "node patch-sdk.mjs",
    "setup:models:legacy": "bun run scripts/setup-models.ts"
  },
  "keywords": [
    "qvac",
    "coffee",
    "ordering",
    "voice-control",
    "ai",
    "speech-recognition",
    "x402",
    "wdk",
    "tether",
    "payments",
    "agentic"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@qvac/sdk": "^0.13.5",
    "@tetherto/wdk": "^1.0.0-beta.5",
    "@tetherto/wdk-wallet-btc": "^1.0.0-beta.4",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.4",
    "@tetherto/wdk-wallet-solana": "^1.0.0-beta.4",
    "@tetherto/wdk-wallet-spark": "^1.0.0-beta.6",
    "@tetherto/wdk-wallet-tron": "^1.0.0-beta.3",
    "ethers": "^6.13.0",
    "micro-key-producer": "^0.8.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.11.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "overrides": {
    "hypercore-storage": "3.0.2",
    "corestore": "7.10.0",
    "hypercore": "11.33.1",
    "hyperbee": "2.27.3"
  }
}
