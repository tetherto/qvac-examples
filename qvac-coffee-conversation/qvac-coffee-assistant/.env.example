# =============================================================================
# Coffee Assistant Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Network Mode
# -----------------------------------------------------------------------------
# Controls which blockchain networks to connect to: "testnet" or "mainnet"
# This sets default RPC endpoints and USDT contract addresses
NETWORK_MODE=testnet

# -----------------------------------------------------------------------------
# Payment Configuration
# -----------------------------------------------------------------------------
# Enable real blockchain transactions
# "true" = real transactions on testnet blockchain
# "false" or unset = mock payments (no blockchain, for testing)
USE_REAL_PAYMENTS=true

# Merchant wallet address to receive payments (Tron Nile testnet)
# This is the coffee shop's wallet that receives payments
PAYMENT_RECIPIENT=TVyMXBMZUEbf2TCTfSBah9W44oB9678tyW

# Payment network:
#   tron-nile     = Tron testnet (recommended for USDT - fast & free test tokens)
#   base-sepolia  = Base L2 testnet (Ethereum-based)
#   LIGHTNING     = Bitcoin Lightning Network (instant, near-zero fees)
PAYMENT_NETWORK=tron-nile

# Payment currency - controls what is sent for payments:
#   USDT = TRC-20/ERC-20 USDT token transfer (recommended for stablecoin)
#   TRX  = Native TRON transaction
#   ETH  = Native Ethereum transaction
#   BTC  = Bitcoin via Lightning Network (requires PAYMENT_NETWORK=LIGHTNING)
PAYMENT_CURRENCY=USDT

# -----------------------------------------------------------------------------
# Bitcoin Lightning Configuration (when PAYMENT_CURRENCY=BTC)
# -----------------------------------------------------------------------------
# To use Bitcoin Lightning payments:
#   1. Set PAYMENT_CURRENCY=BTC
#   2. Set PAYMENT_NETWORK=LIGHTNING
#
# Lightning provides instant (<1 second) payments with near-zero fees (~$0.0001)
# Great for micropayments and point-of-sale applications
#
# Example Lightning config:
#   PAYMENT_CURRENCY=BTC
#   PAYMENT_NETWORK=LIGHTNING

# -----------------------------------------------------------------------------
# Phoenixd Lightning Wallet (Non-Custodial)
# -----------------------------------------------------------------------------
# Phoenixd is a non-custodial Lightning daemon by ACINQ
# See qvac-wallet/README.md for setup instructions
#
# 1. Download: https://github.com/ACINQ/phoenixd/releases
# 2. Run: ./phoenixd
# 3. Get password: cat ~/.phoenix/phoenix.conf
#
PHOENIXD_URL=http://localhost:9740
PHOENIXD_PASSWORD=your-password-from-phoenix-conf

# -----------------------------------------------------------------------------
# Shop Wallet Addresses (optional - for multi-chain support)
# -----------------------------------------------------------------------------
# SHOP_WALLET_ETH=0x742d35Cc6634C0532925a3b844D9C5c8b7b6e5f6
# SHOP_WALLET_BTC=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
# SHOP_WALLET_SOL=DYw8jCTfwHNRJhhmFcbXvVDTqWMEVFBX6ZKUmG5CNSKK
# SHOP_WALLET_TRX=TLyqzVGLV1srkB7dToTAEqgDSfPtXRJZYH

# -----------------------------------------------------------------------------
# Coffee Shop API
# -----------------------------------------------------------------------------
COFFEE_SHOP_API_URL=http://localhost:3457

# -----------------------------------------------------------------------------
# Tether WDK Configuration
# -----------------------------------------------------------------------------
# Seed phrase for WDK wallet (optional)
# If not set, a new seed phrase will be auto-generated and saved to:
#   data/tether-wdk-seed.json
# ⚠️  NEVER commit real seed phrases to git!
# WDK_SEED_PHRASE=your twelve word seed phrase here

# -----------------------------------------------------------------------------
# Custom RPC Endpoints (optional - overrides NETWORK_MODE defaults)
# -----------------------------------------------------------------------------
# ETH_RPC_URL=https://sepolia.drpc.org
# SOLANA_RPC_URL=https://api.devnet.solana.com
# TRON_RPC_URL=https://nile.trongrid.io
# BTC_NETWORK=testnet

# -----------------------------------------------------------------------------
# Models (Voice Assistant)
# -----------------------------------------------------------------------------
# Path to Qwen LLM model (optional - leave empty for rule-based extraction)
# Download from: https://huggingface.co/Qwen/Qwen3-4B-Instruct-GGUF
# LLM_MODEL_PATH=./models/Qwen3-4B-Instruct-2507-Q8_0.gguf

# TTS Voice (norman, ryan, semaine)
# norman: SDK default, US English male
# ryan: High quality US English male (requires download)
# semaine: British English female (requires download)
TTS_VOICE=ryan

# TTS Model directory for custom voices
# TTS_MODEL_DIR=./models/tts

# eSpeak data path (required for TTS phonemization)
# macOS (Homebrew): /opt/homebrew/Cellar/espeak-ng/1.52.0/share/espeak-ng-data
# Linux: /usr/share/espeak-ng-data
# Windows: C:\Program Files\eSpeak NG\espeak-ng-data
ESPEAK_DATA_PATH=/opt/homebrew/Cellar/espeak-ng/1.52.0/share/espeak-ng-data

# -----------------------------------------------------------------------------
# Testnet Faucets (to get test tokens)
# -----------------------------------------------------------------------------
# Tron Nile (USDT + TRX):
#   https://nileex.io/
#   https://nile.tronscan.org/#/
#
# Base Sepolia (ETH + USDC):
#   https://www.alchemy.com/faucets/base-sepolia
#   https://faucet.circle.com/
#
# Ethereum Sepolia (ETH):
#   https://sepoliafaucet.com/
#
# Bitcoin Lightning (testnet):
#   Use Spark SDK with regtest or testnet mode

# Enable QR Code generation for orders (true/false)
ENABLE_QR_CODE=true

# LLM Model Configuration
LLM_MODEL_PATH=./models/Qwen3-4B-Instruct-2507-Q8_0.gguf
TTS_MODEL_DIR=./models/tts

# Agent Configuration
MAX_TURNS=25
VERBOSE=false

# For generating the link for QR Codes
ORDER_QR_RECEIPT_BASE_URL=http://localhost:3470
