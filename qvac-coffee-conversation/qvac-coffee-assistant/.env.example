# =============================================================================
# Coffee Conversation - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust:  cp .env.example .env
# This demo prices everything in BITCOIN SATS and settles over the Lightning
# Network (x402 flow). It is NOT the old USDT/Tron flow. Bun auto-loads .env.

# -----------------------------------------------------------------------------
# Payment mode
# -----------------------------------------------------------------------------
# false / unset = MOCK: a placeholder invoice is shown, any proof is accepted,
#                 no real funds move. This is the safe default for a UI demo.
# true          = REAL: a genuine Lightning invoice is generated (see below).
USE_REAL_PAYMENTS=false

# -----------------------------------------------------------------------------
# REAL Lightning payments (only read when USE_REAL_PAYMENTS=true)
# -----------------------------------------------------------------------------
# There are TWO ways to receive the sats. Pick ONE.
#
# OPTION A - Lightning Address (simplest, no seed, funds land in your wallet):
#   Set PAYMENT_RECIPIENT to a Lightning Address (looks like an email). The shop
#   resolves it via LNURL-pay and the customer's payment goes straight to it.
#   PAYMENT_RECIPIENT=you@yourlightningwallet.com
#
# OPTION B - WDK Spark wallet (self-contained, your own seed):
#   Leave PAYMENT_RECIPIENT unset. The shop mints the invoice from WDK Spark account index 1
#   (derived from the seed); the customer is Spark account index 0. Set WDK_SEED_PHRASE below and
#   the wallet travels entirely in this .env (no seed file needed). Use SPARK_NETWORK=MAINNET for
#   real tiny sats, or REGTEST for the faucet. There is no Spark "testnet".
#
PAYMENT_NETWORK=LIGHTNING
PAYMENT_CURRENCY=BTC
# PAYMENT_RECIPIENT=you@yourlightningwallet.com

# WDK seed (Option B only). If unset, one is auto-generated to data/tether-wdk-seed.json.
# WARNING: never commit a real seed phrase.
# WDK_SEED_PHRASE=your twelve word seed phrase here

# Network for REAL payments (mock mode ignores these). Spark runs MAINNET / SIGNET / REGTEST
# (there is NO "testnet"). For real sats use mainnet + MAINNET.
NETWORK_MODE=mainnet
SPARK_NETWORK=MAINNET

# -----------------------------------------------------------------------------
# Pricing (sats)
# -----------------------------------------------------------------------------
# Fixed demo rate: 1 USD = 1000 sats (so a $3.50 drink = 3500 sats). No live rate.
SATS_PER_USD=1000
# Fallback BTC/USD rate if a live rate is ever fetched (informational only).
BTC_USD_RATE=95000

# -----------------------------------------------------------------------------
# Models / voice
# -----------------------------------------------------------------------------
# Agent LLM: 4b (Qwen3 4B, default, lightest+fastest) | 8b (Qwen3 8B, stronger) | 35b (Qwen3.6 35B-A3B, needs 32GB+ RAM)
AGENT_LLM=4b
# Spoken voice reference (see assets/). Leave default unless you added voices.
# TTS_VOICE=default

# -----------------------------------------------------------------------------
# Ports + receipt link
# -----------------------------------------------------------------------------
# The launcher (server.js) sets these; override only if a port is taken.
# PORT=3461                      # conversation UI
# API_PORT=3462                  # coffee shop API
# COFFEE_SHOP_API_URL=http://localhost:3462
# Base URL the order QR points at (the receipt site).
# ORDER_QR_RECEIPT_BASE_URL=http://localhost:3470

# Enable QR code generation for orders.
ENABLE_QR_CODE=true

# -----------------------------------------------------------------------------
# Legacy multi-chain wallets (NOT used by the sats/Lightning flow; kept for reference)
# -----------------------------------------------------------------------------
# SHOP_WALLET_BTC=bc1q...
# SHOP_WALLET_ETH=0x...
# Phoenixd (alternative non-custodial Lightning daemon, if you wire it in):
# PHOENIXD_URL=http://localhost:9740
# PHOENIXD_PASSWORD=your-password-from-phoenix-conf
